# Kafka configuration
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=gps.updates
KAFKA_TLS_ENABLE=false

# Redis configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_TLS_ENABLE=false

# Cassandra configuration
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=location_tracker
CASSANDRA_TLS_ENABLE=false

# API configuration
HTTP_PORT=8080
JWT_SECRET=super-secret-key
API_KEY=test-api-key

# Monitoring
METRICS_PORT=9090
LOG_LEVEL=info
